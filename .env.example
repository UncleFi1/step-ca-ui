# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# IP адрес сервера (для SSL сертификата и Step-CA)
HOST_IP=192.168.1.100

# Пароль для Step-CA provisioner
CA_PASSWORD=your-strong-password-here

# Имя provisioner (обычно email)
PROVISIONER=admin@home.local

# Секретный ключ для сессий (минимум 32 символа)
SECRET_KEY=change-this-to-a-random-32-char-string

# Пароль для PostgreSQL
POSTGRES_PASSWORD=your-postgres-password-here
